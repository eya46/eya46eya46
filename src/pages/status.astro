---
import Layout from "../layouts/Layout.astro";
import Box from "../layouts/Box.astro";
import ServerList from "../components/status/ServerList.vue";
import { nezha } from "../utils/nezha";

const preload = nezha.getData();
---

<Layout title="eya46-探针">
  <div class="space-y-5">
    <Box showDecoration={false}>
      <div class="mt-4">
        <ServerList client:load preload={preload} />
      </div>
    </Box>
  </div>
</Layout>
