---
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import GitHash from "../components/GitHash.astro";
import Version from "../components/Version.astro";
import FooterDiv from "../components/FooterDiv.astro";
import Nav from "../components/Nav.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta content="eya46的主页" name="description" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <link href="/favicon.jpg" rel="icon" type="image/jpeg" />
    <meta content={Astro.generator} name="generator" />
    <title>{title}</title>
    <ClientRouter />
    <!-- 顶部加载进度条样式 -->
    <style>
      #nprogress {
        pointer-events: none;
      }
      #nprogress .bar {
        background: #3b82f6; /* Tailwind blue-500 */
        position: fixed;
        z-index: 1031;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
      }
      #nprogress .peg {
        display: block;
        position: absolute;
        right: 0px;
        width: 100px;
        height: 100%;
        box-shadow: 0 0 10px #3b82f6, 0 0 5px #3b82f6;
        opacity: 1.0;
        transform: rotate(3deg) translate(0px, -4px);
      }
    </style>
  </head>
  <body>
    <!-- 用 id 标识，并在 is:inline 脚本中处理它，不依赖 transition:persist 以免被框架重构 -->
    <div id="bg-anim" class="bg-gradient-animated fixed inset-0 -z-10" transition:persist></div>
    <GoogleAnalytics />
    <main class="max-width mx-auto bg-gray-200/50 p-4 backdrop-blur-sm">
      <Nav />
      <div>
        <slot />
      </div>
    </main>
    <footer class="my-1 w-full">
      <FooterDiv>
        <a class="text-gray-500 hover:underline" href="https://beian.miit.gov.cn/" target="_blank">
          湘ICP备2023033688号-1
        </a>
        <a class="text-gray-500 hover:underline" href="https://beian.mps.gov.cn/#/query/webSearch" target="_blank">
          苏公网安备32058302004987号
        </a>
        <a class="text-gray-500 hover:underline" href="https://icp.gov.moe/?keyword=eya46.com" target="_blank">
          萌ICP备20228855号
        </a>
      </FooterDiv>
      <FooterDiv>
        <a class="text-gray-500 hover:underline" href="/test"> 测试页 </a>
        <a
          class="text-gray-500 hover:underline"
          href="https://travel.moe/go.html?travel=on"
          target="_blank"
          title="异次元之旅-跃迁-我们一起去萌站成员的星球旅行吧！"
        >
          异次元之旅
        </a>
        <a class="text-gray-500 hover:underline" href="https://github.com/eya46/eya46eya46" target="_blank">
          项目主页
        </a>
        <span class="flex items-center space-x-0.5 text-gray-500 select-none [&>span]:inline-block">
          <span>🔖</span>
          <span>
            <Version />
            ( <GitHash /> )
          </span>
        </span>
        <a class="text-gray-500 hover:underline" href="https://astro.build/" target="_blank">
          {Astro.generator}
        </a>
      </FooterDiv>
      <FooterDiv>
        <span>
          © 2020 - {new Date().getFullYear()} eya46 All rights reserved
        </span>
      </FooterDiv>
    </footer>
    <script>
      // Nav sticky: 向下滚动隐藏，向上滚动显示
      let lastScrollY = window.scrollY;

      document.addEventListener("astro:before-preparation", () => {
        // 确保 nav 在截图时可见
        const nav = document.querySelector("[data-nav-sticky]");
        if (nav) nav.classList.remove("nav-hidden");
      });

      window.addEventListener(
        "scroll",
        () => {
          const nav = document.querySelector("[data-nav-sticky]");
          if (!nav) return;
          const currentY = window.scrollY;
          if (currentY > lastScrollY && currentY > 60) {
            nav.classList.add("nav-hidden");
          } else {
            nav.classList.remove("nav-hidden");
          }
          lastScrollY = currentY;
        },
        { passive: true }
      );

      document.addEventListener("astro:after-swap", () => {
        lastScrollY = window.scrollY;
      });

      // 简易 NProgress 进度条实现
      let progressTimer: number | null = null;
      let progressElement: HTMLElement | null = null;

      function startProgress() {
        if (progressElement) return;
        progressElement = document.createElement("div");
        progressElement.id = "nprogress";
        progressElement.innerHTML = '<div class="bar" style="width: 0%"><div class="peg"></div></div>';
        document.body.appendChild(progressElement);

        let width = 0;
        const bar = progressElement.querySelector(".bar") as HTMLElement;
        
        progressTimer = window.setInterval(() => {
          if (width >= 90) return;
          // 模拟进度增加
          width += (90 - width) * 0.1;
          bar.style.width = width + "%";
        }, 200);
      }

      function stopProgress() {
        if (progressTimer) {
          clearInterval(progressTimer);
          progressTimer = null;
        }
        if (progressElement) {
          const bar = progressElement.querySelector(".bar") as HTMLElement;
          if (bar) bar.style.width = "100%";
          setTimeout(() => {
            if (progressElement && progressElement.parentNode) {
              progressElement.parentNode.removeChild(progressElement);
            }
            progressElement = null;
          }, 200); // 等待动画完成
        }
      }

      // Astro View Transitions 路由钩子
      document.addEventListener("astro:before-preparation", () => {
        startProgress();
      });
      document.addEventListener("astro:page-load", () => {
        stopProgress();
      });

      // 同步背景动画进度，防止 Astro View Transitions 重新插入 DOM 导致 CSS 动画重置
      if (!window.bgAnimationStartTime) {
        window.bgAnimationStartTime = performance.now();
      }

      function syncBgAnimation() {
        const bg = document.getElementById("bg-anim");
        if (bg) {
          const elapsed = (performance.now() - window.bgAnimationStartTime) / 1000;
          // 使用负的 animation-delay 让动画快进到当前时间点
          bg.style.animationDelay = `-${elapsed}s`;
        }
      }

      // 首次加载同步一次
      syncBgAnimation();

      // 每次页面 DOM 被替换后重新同步时间
      document.addEventListener("astro:after-swap", syncBgAnimation);
    </script>
  </body><style is:global>
    @import "tailwindcss";

    .max-width {
      max-width: calc(100% - 2rem);
    }

    html {
      font-family: system-ui, sans-serif;
      min-width: 23.5rem;
    }

    main {
      width: 50rem;
      font-size: 20px;
      line-height: 1.6;
      min-height: calc(100vh - 4.5rem);
    }

    @keyframes gradient {
      0% {
        background-position: 0 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0 50%;
      }
    }

    .bg-gradient-animated {
      background: linear-gradient(270deg, #f38181, #fce38a, #eaffd0, #95e1d3);
      background-size: 600% 600%;
      animation:
        gradient 20s ease-in-out infinite,
        rotate 10s linear infinite;
    }

    .avatar-twister {
      transform: scale(1) rotate(0);
      transition: transform 0.5s;
    }

    .avatar-twister:hover {
      transform: scale(1.5) rotate(360deg);
    }

    .nav-hidden {
      transform: translateY(-100%);
    }
  </style>
</html>
